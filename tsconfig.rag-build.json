{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "es2020"],
    "module": "commonjs",
    "moduleResolution": "node",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "/tmp/blistering-barnacles-rag-build",
    "rootDir": ".",
    "noEmit": false
  },
  "include": [
    "scripts/build-rag-corpus.ts",
    "lib/rag/**/*.ts",
    "lib/help/**/*.ts",
    "lib/guide/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
