{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "es2020"],
    "module": "commonjs",
    "moduleResolution": "node",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "/tmp/blistering-barnacles-guide-tests",
    "rootDir": ".",
    "noEmit": false
  },
  "include": ["lib/guide/**/*.ts"],
  "exclude": ["node_modules"]
}
